[submodule "astronvim"]
	path = .config/nvim
	url = https://github.com/AstroNvim/AstroNvim
[submodule "astronvim_config"]
	path = .config/astronvim/lua/user
	url = https://github.com/paynejj/astronvim_config.git
[submodule "antidote"]
	path = .config/zsh/.antidote
	url = https://github.com/mattmc3/antidote.git
[submodule "fzf"]
	path = .config/programs/fzf
	url = https://github.com/junegunn/fzf.git
[submodule "neovim"]
	path = .config/programs/neovim
	url = https://github.com/neovim/neovim.git
